DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_HSTS_SECONDS=3600

# Use somente a URL protegida do Session Pooler; nunca versione usuário ou senha reais.
# DATABASE_URL=postgresql://estagios_app.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Alternativa local reconhecida pelo settings: PROJETO_ESTAGIOS_DATABASE_URL
PLATFORM_REPOSITORY=django

# Habilite migrations apenas na etapa aprovada de publicação.
RUN_MIGRATIONS=false
