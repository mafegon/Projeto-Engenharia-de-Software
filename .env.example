DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_HSTS_SECONDS=3600

# Integração futura com o Supabase. Não habilite até a equipe de banco fornecer
# e aprovar schema, migrations e a URL protegida do Session pooler.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Database migrations belong to the database workflow and stay disabled by default.
RUN_MIGRATIONS=false
